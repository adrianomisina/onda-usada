# ─── Banco de Dados ───────────────────────────────────────────────────────────
# Cole sua connection string do MongoDB Atlas:
MONGODB_URI=mongodb+srv://SEU_USUARIO:SUA_SENHA@SEU_CLUSTER.mongodb.net/?appName=SEU_APP

# ─── Mercado Pago ─────────────────────────────────────────────────────────────
# Use tokens de TESTE para dev e PRODUÇÃO para prod:
MP_ACCESS_TOKEN=TEST-ou-PROD-seu-token-aqui
MP_PUBLIC_KEY=TEST-ou-PROD-sua-public-key
MP_CLIENT_ID=seu-client-id
MP_CLIENT_SECRET=seu-client-secret

# ─── URL Pública da Aplicação ─────────────────────────────────────────────────
# Necessário para o Mercado Pago redirecionar após pagamento:
APP_URL=https://seu-site.netlify.app
